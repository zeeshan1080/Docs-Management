{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=XYZ_Database;Trusted_Connection=True;"
  },

  "Jwt": {
    "Key": "YOUR_SECRET_KEY_HERE",
    "Issuer": "PrimeDoc",
    "Audience": "PrimeDocUsers",
    "ExpireMinutes": 240
  },

  "FileStorage": {
    "RootPath": "wwwroot/uploads",
    "MaxUploadBytes": 209715200
  },

  "DocumentViewer": {
    "PublicOrigin": "",
    "TokenMinutes": 15
  },

  "Cors": {
    "Origins": [ "http://localhost:4200" ]
  },

  "SpaPublic": {
    "BaseUrl": "http://localhost:4200"
  },

  "Email": {
    "Provider": "GmailSmtp",
    "DefaultFromEmail": "example@example.com",
    "DefaultFromName": "PrimeDoc",
    "PublicLogoUrl": "",
    "ApprovalRequestRecipient": "example@example.com",
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "UseStartTls": true,
      "Username": "example@example.com",
      "Password": "YOUR_EMAIL_PASSWORD"
    }
  },

  "DevSeed": {
    "Enabled": false,
    "AdminEmail": "admin@example.com",
    "AdminPassword": "StrongPassword123!"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}